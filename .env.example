# CS2 Market Analytics Platform — environment configuration
# Copy this file to .env and fill in all required values.

# ── Required ──────────────────────────────────────────────────────────────────

# Steam Market session cookie (required for live price fetching and inventory sync).
# Obtain from browser DevTools → Application → Cookies → steamcommunity.com
# → steamLoginSecure (the long token, NOT the session cookie).
STEAM_LOGIN_SECURE=

# Your Steam 64-bit account ID (required for inventory sync via PV-29).
# Find it at: https://steamcommunity.com/id/YOUR_PROFILE/?xml=1 → steamid64
STEAM_ID=

# ── PostgreSQL (TimescaleDB) ──────────────────────────────────────────────────

# Docker service name (use "localhost" for local dev outside Docker).
DB_HOST=db
DB_PORT=5432
POSTGRES_DB=cs2
POSTGRES_USER=cs2user
POSTGRES_PASSWORD=cs2pass

# Optional: set DATABASE_URL directly to override the above vars.
# DATABASE_URL=postgresql+psycopg2://cs2user:cs2pass@db:5432/cs2

# ── Redis (Celery broker) ─────────────────────────────────────────────────────

CELERY_BROKER_URL=redis://redis:6379/0
# CELERY_RESULT_BACKEND is built automatically from POSTGRES_* vars in celery_app.py.

# ── Server ports ──────────────────────────────────────────────────────────────

API_HOST=0.0.0.0
API_PORT=8000
DASHBOARD_PORT=8050

# ── Logging ───────────────────────────────────────────────────────────────────

# One of: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO

# ── Market constants (override only if Valve changes fees) ───────────────────

# Default 1.15 = 15% Steam Market fee
STEAM_FEE_DIVISOR=1.15

# Fixed per-transaction fee in KZT (~$0.01 at current rates)
STEAM_FEE_FIXED_KZT=5.0

# Standard CS2 case key price in KZT
KEY_PRICE_KZT=1200.0

# ── Signal thresholds (tune to market conditions) ─────────────────────────────

# Minimum price to emit a ratio signal (KZT)
RATIO_FLOOR_KZT=120.0

# Momentum sell threshold for event-matched containers (%)
MOMENTUM_EVENT_THRESHOLD=15.0

# ── Flip quality gates ────────────────────────────────────────────────────────

FLIP_MIN_NET_MARGIN=0.05
FLIP_SELL_TARGET_CAP=1.20

# ── Liquidity & order book guards ────────────────────────────────────────────

LIQUIDITY_MIN_VOLUME=10.0
WALL_MAX_DAYS=7

# ── Notifications (optional) ─────────────────────────────────────────────────

# Webhook endpoint for SuperDealDetected / AuthError alerts (PV-17).
# Leave empty to disable.
WEBHOOK_URL=

# ── Event calendar (optional) ────────────────────────────────────────────────

EVENTS_YAML_PATH=data/events.yaml
EVENTS_REMOTE_URL=

# ── Proxy rotation (optional) ────────────────────────────────────────────────

# Comma-separated list of HTTP proxies, e.g.: http://user:pass@host:port
PROXY_LIST=
